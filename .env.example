# Strava OAuth (from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:5173/auth/callback

# Storage
OSTINATO_DB_PATH=./data/ostinato.db
OSTINATO_SECRETS_PATH=./data/secrets.json

# Server
PORT=5173
HOST=0.0.0.0

# DEV-only: enables /api/seed and other dev-only endpoints
NODE_ENV=development
